POSTGRES_USER=app
POSTGRES_PASSWORD=changeme
POSTGRES_DB=appdb

DATABASE_URL=postgresql+asyncpg://app:changeme@postgres:5432/appdb
HOST=0.0.0.0
PORT=8000

VITE_API_URL=http://localhost:8000

# CORS: comma-separated origins the API will accept (e.g. frontend URL)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Auth0 (create app at https://manage.auth0.com)
# Add http://localhost:5173 to Allowed Callback URLs, Logout URLs, and Allowed Web Origins
VITE_AUTH0_DOMAIN=your-tenant.us.auth0.com
VITE_AUTH0_CLIENT_ID=your_client_id

# Backend: same Auth0 domain (for syncing logged-in users to the users table)
AUTH0_DOMAIN=your-tenant.us.auth0.com

# OpenEI (optional, for utility rates example script)
OPENEI_API_KEY=
