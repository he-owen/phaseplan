{
  "name": "henhacks2026",
  "private": true,
  "scripts": {
    "dev": "npm run dev --prefix frontend",
    "dev:backend": "cd backend && python -m uvicorn main:app --reload --host 0.0.0.0 --port 8000",
    "build": "npm run build --prefix frontend",
    "db:generate": "dotenv -e .env -- prisma generate --schema=./database/schema.prisma",
    "db:push": "dotenv -e .env -- prisma db push --schema=./database/schema.prisma",
    "db:migrate": "dotenv -e .env -- prisma migrate dev --schema=./database/schema.prisma",
    "db:pull": "dotenv -e .env -- prisma db pull --schema=./database/schema.prisma",
    "db:studio": "dotenv -e .env -- prisma studio --schema=./database/schema.prisma",
    "db:seed": "dotenv -e .env -- prisma db seed --schema=./database/schema.prisma"
  },
  "prisma": {
    "seed": "node database/seed.js"
  },
  "devDependencies": {
    "dotenv-cli": "^7.4.2",
    "prisma": "^6.0.0"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2"
  }
}
