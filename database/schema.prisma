generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String           @id
  email              String           @unique
  utilityProv        String?          @map("utility_prov")
  selectedProviderId String?          @map("selected_provider_id")
  selectedProvider   UtilityProvider? @relation(fields: [selectedProviderId], references: [id])
  locations          Location[]
  billHistory        BillHistory[]
  devices            Device[]

  @@map("users")
}

model Location {
  id     String @id @default(uuid()) @map("location_id")
  userId String @map("user_id")
  zip    String @map("zip")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("locations")
}

model Device {
  id                 String  @id @default(uuid()) @map("device_id")
  userId             String  @map("user_id")
  name               String
  type               String
  brand              String?
  model              String?
  hourlyEnergy       Float?  @map("hourly_energy")
  standbyEnergy      Float?  @map("standby_energy")
  activeEnergy       Float?  @map("active_energy")
  isSmart            Boolean @default(false) @map("is_smart")
  runDurationMinutes Int?    @map("run_duration_minutes")
  user               User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("devices")
}

model BillHistory {
  id          String   @id @default(uuid()) @map("bill_id")
  userId      String   @map("user_id")
  billTotal   Decimal  @map("bill_total") @db.Decimal(12, 2)
  createdDate DateTime @default(now()) @map("created_date") @db.Timestamptz(6)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("bill_history")
}

model UtilityProvider {
  id                  String       @id @default(uuid()) @map("provider_id")
  zipCode             String       @map("zip_code")
  utilityName         String       @map("utility_name")
  rateName            String       @map("rate_name")
  sector              String       @default("Residential")
  rateStructureJson   Json?        @map("rate_structure_json")
  weekdayScheduleJson Json?        @map("weekday_schedule_json")
  weekendScheduleJson Json?        @map("weekend_schedule_json")
  fuelAdjustmentsJson Json?        @map("fuel_adjustments_json")
  fetchedAt           DateTime     @default(now()) @map("fetched_at") @db.Timestamptz(6)
  hourlyRates         HourlyRate[]
  users               User[]

  @@unique([zipCode, utilityName, rateName])
  @@index([zipCode])
  @@map("utility_providers")
}

model HourlyRate {
  id           String          @id @default(uuid()) @map("rate_id")
  providerId   String          @map("provider_id")
  date         DateTime        @map("date") @db.Date
  hour         Int             @map("hour")
  baseRate     Decimal         @map("base_rate") @db.Decimal(10, 6)
  deliveryCost Decimal         @map("delivery_cost") @db.Decimal(10, 6)
  totalRate    Decimal         @map("total_rate") @db.Decimal(10, 6)
  periodIndex  Int             @map("period_index")
  periodLabel  String          @map("period_label")
  provider     UtilityProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@unique([providerId, date, hour])
  @@index([providerId, date])
  @@map("hourly_rates")
}

